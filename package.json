{
	"name": "lifi-fee-indexer",
	"version": "1.0.0",
	"private": true,
	"description": "LI.FI FeeCollector event indexer — Polygon + Stellar Testnet",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"scanner": "tsx src/scanner.ts",
		"server": "tsx src/server.ts",
		"test": "vitest --run",
		"test:unit": "vitest --run --reporter=verbose unit.spec",
		"test:int": "vitest --run --reporter=verbose int.spec",
		"test:cov": "vitest --run --coverage",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"check:types": "tsc --noEmit"
	},
	"dependencies": {
		"@fastify/rate-limit": "^9.1.0",
		"@stellar/stellar-sdk": "^13.1.0",
		"@typegoose/typegoose": "^12.8.0",
		"fastify": "^5.2.0",
		"mongoose": "^8.9.0",
		"pino": "^9.5.0",
		"pino-pretty": "^13.0.0",
		"reflect-metadata": "^0.2.2",
		"viem": "^2.21.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.10.0",
		"@vitest/coverage-v8": "^2.1.8",
		"mongodb-memory-server": "^10.1.4",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "mongodb-memory-server"]
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
