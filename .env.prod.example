# Tailscale — generate at: Tailscale admin → Settings → Keys → Generate auth key (reusable + ephemeral)
TS_AUTH_KEY=tskey-auth-REPLACE_ME
TS_HOSTNAME=lifi-fee-indexer

# MongoDB (authenticated)
MONGO_USER=lifi
MONGO_PASSWORD=REPLACE_ME_USE_openssl_rand_-base64_24

# Polygon RPC (drpc.org free tier has archive data for block 78.6M, 1000 block limit)
POLYGON_RPC_URL=https://polygon.drpc.org

# FeeCollector contract address (Polygon mainnet)
FEE_COLLECTOR_ADDRESS=0xbD6C7B0d2f68c2b7805d88388319cfB6EcB50eA9

# Stellar Soroban RPC (testnet)
STELLAR_HORIZON_URL=https://soroban-testnet.stellar.org

# Stellar contract address (oracle/price-feed on testnet)
STELLAR_INTEGRATOR_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Scanner settings (BATCH_SIZE=1000 for drpc.org free tier compatibility)
BATCH_SIZE=1000
EVM_START_BLOCK=78600000
POLL_INTERVAL_MS=10000

# Server
HOST=0.0.0.0
PORT=3000

# Logging
LOG_LEVEL=info
