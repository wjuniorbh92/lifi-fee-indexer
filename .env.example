# MongoDB
MONGODB_URI=mongodb://localhost:27017/lifi-fee-indexer

# Polygon RPC (free endpoints work for recent blocks)
# Options: polygon-bor-rpc.publicnode.com, rpc.ankr.com/polygon, or Alchemy/Infura free tier
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# Stellar Soroban RPC (testnet)
STELLAR_HORIZON_URL=https://soroban-testnet.stellar.org

# FeeCollector contract address (Polygon)
FEE_COLLECTOR_ADDRESS=0xbD6C7B0d2f68c2b7805d88388319cfB6EcB50eA9

# Stellar contract address (leave empty to disable Stellar scanner)
# Default: oracle/price-feed contract on testnet that emits "fee" events
STELLAR_INTEGRATOR_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Scanner settings
BATCH_SIZE=2000
EVM_START_BLOCK=78600000
POLL_INTERVAL_MS=10000

# Server
HOST=0.0.0.0
PORT=3000

# Logging
LOG_LEVEL=info
